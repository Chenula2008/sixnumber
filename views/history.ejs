<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My History - Six Number</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <!-- Montag Ad Code -->
    <script src="https://quge5.com/88/tag.min.js" data-zone="254010" async data-cfasync="false"></script>
    <!-- ADSTERRA AD CODE -->
    <script src="https://pl30089548.effectivecpmnetwork.com/ab/96/8d/ab968d8cfc05f32a5f967786f69c2118.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #0a0e27 0%, #1a1040 50%, #0d1b3e 100%); min-height: 100vh; color: #ffffff; overflow-x: hidden; }
        body::before { content: ''; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(circle at 20% 80%, rgba(120, 80, 255, 0.08) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(0, 200, 255, 0.08) 0%, transparent 50%); pointer-events: none; z-index: 0; }
        .shape { position: fixed; border-radius: 50%; filter: blur(80px); opacity: 0.4; z-index: 0; animation: float 20s infinite ease-in-out; }
        .shape-1 { width: 400px; height: 400px; background: linear-gradient(135deg, #7c3aed, #00d4ff); top: -100px; left: -100px; }
        .shape-2 { width: 300px; height: 300px; background: linear-gradient(135deg, #f472b6, #8b5cf6); bottom: -50px; right: -50px; }
        @keyframes float { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(20px, -20px); } }

        /* Navbar */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10, 14, 39, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            padding: 0 30px;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .nav-brand {
            font-size: 24px;
            font-weight: 900;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: white;
        }

        .nav-brand span:first-child { color: #ffffff; }
        .nav-brand span:nth-child(2) { 
            background: linear-gradient(135deg, #00d4ff, #7c3aed);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* 🇱🇰 Sri Lanka Flag in Navbar */
        .nav-brand .flag {
            font-size: 20px;
            margin-left: 2px;
            animation: subtle-wave 3s ease-in-out infinite;
        }

        .nav-balance { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); padding: 10px 20px; border-radius: 50px; }
        .balance-icon { width: 36px; height: 36px; background: linear-gradient(135deg, #10b981, #059669); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .balance-info { display: flex; flex-direction: column; }
        .balance-label { font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; }
        .balance-amount { font-size: 20px; font-weight: 800; color: #10b981; }
        .nav-actions { display: flex; gap: 10px; }
        .nav-btn { padding: 10px 18px; border-radius: 10px; text-decoration: none; font-size: 13px; font-weight: 600; transition: all 0.3s ease; display: flex; align-items: center; gap: 6px; border: 1px solid transparent; }
        .nav-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,0.3); }
        .btn-withdraw { background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; }
        .btn-history { background: rgba(139, 92, 246, 0.2); color: #a78bfa; border-color: rgba(139, 92, 246, 0.3); }
        .btn-admin { background: linear-gradient(135deg, #06b6d4, #0891b2); color: white; }
        .btn-logout { background: rgba(239, 68, 68, 0.15); color: #f87171; border-color: rgba(239, 68, 68, 0.3); }

        /* Main Content */
        .main-content { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; padding: 40px 20px; animation: fadeInUp 0.6s ease; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        .page-header { margin-bottom: 30px; }
        .page-title { font-size: 32px; font-weight: 800; margin-bottom: 8px; }
        .page-subtitle { font-size: 15px; color: rgba(255, 255, 255, 0.5); }

        /* Stats Row */
        .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 30px; }
        .stat-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 20px; backdrop-filter: blur(10px); text-align: center; transition: all 0.3s ease; }
        .stat-icon { font-size: 24px; margin-bottom: 8px; }
        .stat-value { font-size: 24px; font-weight: 800; }
        .stat-label { font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }

        /* 🚀 Daily Entries Card Special Styles */
        .stat-card.daily-entries {
            position: relative;
            overflow: hidden;
        }
        .stat-card.daily-entries.limit-reached {
            border: 2px solid rgba(239, 68, 68, 0.5);
            background: rgba(239, 68, 68, 0.05);
            animation: pulseWarning 2s infinite;
        }
        @keyframes pulseWarning {
            0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.3); }
            50% { box-shadow: 0 0 20px 5px rgba(239, 68, 68, 0.15); }
        }

        .progress-bar {
            width: 100%;
            height: 6px;
            background: rgba(0,0,0,0.3);
            border-radius: 3px;
            margin-top: 10px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 0.5s ease;
        }
        .progress-fill.safe { background: linear-gradient(90deg, #10b981, #00d4ff); }
        .progress-fill.warning { background: linear-gradient(90deg, #f59e0b, #ef4444); }
        .progress-fill.danger { background: linear-gradient(90deg, #ef4444, #f59e0b); }

        .status-tag {
            margin-top: 10px;
            padding: 5px 10px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
        }
        .status-tag.safe {
            background: rgba(16, 185, 129, 0.2);
            border: 1px solid rgba(16, 185, 129, 0.4);
            color: #34d399;
        }
        .status-tag.warning {
            background: rgba(245, 158, 11, 0.2);
            border: 1px solid rgba(245, 158, 11, 0.4);
            color: #fbbf24;
        }
        .status-tag.danger {
            background: rgba(239, 68, 68, 0.2);
            border: 1px solid rgba(239, 68, 68, 0.4);
            color: #f87171;
        }

        /* Table Card */
        .table-card { background: rgba(255,255,255,0.03); backdrop-filter: blur(40px); border: 1px solid rgba(255,255,255,0.08); border-radius: 24px; overflow: hidden; }
        .table-header { padding: 20px 25px; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: space-between; align-items: center; }
        .table-title { font-size: 18px; font-weight: 700; }
        .table-count { font-size: 13px; color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.05); padding: 4px 12px; border-radius: 20px; }
        
        .table-wrapper { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 16px 25px; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.4); font-weight: 600; border-bottom: 1px solid rgba(255,255,255,0.06); }
        td { padding: 20px 25px; font-size: 14px; border-bottom: 1px solid rgba(255,255,255,0.04); color: rgba(255,255,255,0.8); vertical-align: top; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: rgba(255,255,255,0.02); }

        .amount-cell { font-weight: 700; color: #ffffff; font-size: 15px; }
        
        /* 🚀 NEW: Bank Details Styling */
        .bank-details {
            font-size: 12px;
            color: rgba(255,255,255,0.7);
            line-height: 1.6;
            max-width: 250px;
        }
        .bank-details strong {
            color: #fbbf24;
            font-weight: 600;
        }
        .address-cell { 
            font-family: monospace; 
            font-size: 12px; 
            color: rgba(255,255,255,0.5); 
            max-width: 150px; 
            overflow: hidden; 
            text-overflow: ellipsis; 
            white-space: nowrap; 
        }

        /* Status Badges */
        .status-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 50px; font-size: 12px; font-weight: 600; }
        .status-pending { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.2); }
        .status-approved { background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
        .status-rejected { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }

        .empty-state { text-align: center; padding: 60px 20px; }
        .empty-icon { font-size: 48px; margin-bottom: 15px; opacity: 0.5; }
        .empty-title { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
        .empty-text { font-size: 14px; color: rgba(255,255,255,0.4); margin-bottom: 20px; }
        .empty-btn { display: inline-block; padding: 10px 20px; background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; text-decoration: none; border-radius: 10px; font-weight: 600; font-size: 13px; transition: all 0.3s ease; }
        .empty-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(59, 130, 246, 0.3); }

        /* Footer */
        .footer {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 20px;
            color: rgba(255, 255, 255, 0.336);
            font-size: 12px;
        }
        .footer-section { margin-top: 40px; text-align: center; padding-top: 25px; border-top: 1px solid rgba(255, 255, 255, 0.06); }
        .footer-links { display: flex; justify-content: center; gap: 25px; margin-bottom: 15px; }
        .footer-link { color: rgba(255, 255, 255, 0.6); text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.3s ease; display: flex; align-items: center; gap: 6px; }
        .footer-link:hover { color: #00d4ff; transform: translateY(-2px); }
        .footer-copyright { color: rgba(255, 255, 255, 0.3); font-size: 12px; margin: 0; }

        /* Floating Support Button */
        .floating-support-btn { position: fixed; bottom: 30px; right: 30px; width: 60px; height: 60px; background: linear-gradient(135deg, #00d4ff, #7c3aed); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px; text-decoration: none; box-shadow: 0 8px 25px rgba(124, 58, 237, 0.5); z-index: 9999; transition: all 0.3s ease; animation: pulse-support 2s infinite; }
        .floating-support-btn:hover { transform: scale(1.1) rotate(10deg); box-shadow: 0 12px 35px rgba(124, 58, 237, 0.7); }
        .support-tooltip { position: absolute; right: 75px; background: rgba(15, 23, 42, 0.9); color: #fff; padding: 8px 12px; border-radius: 8px; font-size: 13px; font-weight: 600; white-space: nowrap; opacity: 0; pointer-events: none; transition: all 0.3s ease; transform: translateX(10px); border: 1px solid rgba(255,255,255,0.1); }
        .floating-support-btn:hover .support-tooltip { opacity: 1; transform: translateX(0); }
        @keyframes pulse-support { 0% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0.6); } 70% { box-shadow: 0 0 0 15px rgba(124, 58, 237, 0); } 100% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0); } }

        @media (max-width: 768px) {
            .navbar { padding: 0 15px; height: auto; padding: 15px; flex-wrap: wrap; gap: 10px; }
            .nav-actions { flex-wrap: wrap; justify-content: center; }
            .page-title { font-size: 24px; }
            th, td { padding: 15px; }
            .hide-mobile { display: none; }
        }
    </style>
</head>
<body>
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>

    <!-- Navbar -->
    <nav class="navbar">
        <!-- 🇱🇰 NAVBAR WITH SRI LANKAN FLAG -->
        <a href="/dashboard" onclick="window.open('https://omg10.com/4/11208116', '_blank');" class="nav-brand">
            <span>Six</span>
            <span>Number</span>
            <span class="flag">🇱🇰</span>
        </a>
        <div class="nav-balance">
            <div class="balance-icon">💰</div>
            <div class="balance-info">
                <span class="balance-label">Balance</span>
                <span class="balance-amount">$<%= (user.walletCents / 100).toFixed(3) %></span>
            </div>
        </div>
        <div class="nav-actions">
            <a href="/withdraw" class="nav-btn btn-withdraw" onclick="window.open('https://omg10.com/4/11208116', '_blank');">💸 Withdrawal</a>
            <a href="/history" class="nav-btn btn-history" onclick="window.open('https://omg10.com/4/11208116', '_blank');">📋 History</a>
            <a href="/daily-tasks" class="nav-btn" style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white; border: none;" onclick="window.open('https://omg10.com/4/11208116', '_blank');">📅 Daily Tasks</a>
            <a href="/profile" class="nav-btn btn-profile" style="background: #f472b6; color: #ffffff; border: 1px solid rgba(236, 72, 153, 0.2);" onclick="window.open('https://omg10.com/4/11208116', '_blank');">👤 Profile</a>
            <% if (user.isAdmin || user.role === 'admin' || user.username === 'admin') { %>
                <a href="/admin" class="nav-btn btn-admin">🛡️ Admin</a>
            <% } %>
            <a href="/logout" class="nav-btn btn-logout" onclick="window.open('https://omg10.com/4/11208116', '_blank');">Logout</a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">My Withdrawal History</h1>
            <p class="page-subtitle">Track the status of all your payout requests.</p>
        </div>

        <!-- Stats Row -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon">📊</div>
                <div class="stat-value"><%= myWithdrawals.length %></div>
                <div class="stat-label">Total Requests</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">⏳</div>
                <div class="stat-value" style="color: #f59e0b;">$<%= (myWithdrawals.filter(w => w.status === 'pending').reduce((sum, w) => sum + w.amountCents, 0) / 100).toFixed(3) %></div>
                <div class="stat-label">Pending Amount</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">✅</div>
                <div class="stat-value" style="color: #10b981;">$<%= (myWithdrawals.filter(w => w.status === 'approved').reduce((sum, w) => sum + w.amountCents, 0) / 100).toFixed(3) %></div>
                <div class="stat-label">Successfully Paid</div>
            </div>
            
            <!-- 🚀 NEW: Daily Entries Tracker -->
            <div class="stat-card daily-entries <%= limitReached ? 'limit-reached' : '' %>">
                <div class="stat-icon">⌨️</div>
                <div class="stat-value" style="color: <%= limitReached ? '#ef4444' : (remainingEntries <= 20 ? '#f59e0b' : '#10b981') %>;">
                    <%= dailyEntries %><span style="font-size: 14px; color: #64748b; font-weight: 500;">/170</span>
                </div>
                <div class="stat-label">Today's Entries</div>
                
                <!-- Progress Bar -->
                <div class="progress-bar">
                    <div class="progress-fill <%= limitReached ? 'danger' : (remainingEntries <= 20 ? 'warning' : 'safe') %>" 
                         style="width: <%= (dailyEntries / 170) * 100 %>%;"></div>
                </div>
                
                <!-- Status Badge -->
                <% if (limitReached) { %>
                    <div class="status-tag danger">
                        🚫 Daily Limit Reached
                    </div>
                <% } else if (remainingEntries <= 20) { %>
                    <div class="status-tag warning">
                        ⚠️ <%= remainingEntries %> entries left
                    </div>
                <% } else { %>
                    <div class="status-tag safe">
                        ✅ <%= remainingEntries %> entries left
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Table -->
        <div class="table-card">
            <div class="table-header">
                <div class="table-title">Recent Transactions</div>
                <div class="table-count"><%= myWithdrawals.length %> Records</div>
            </div>

            <% if (myWithdrawals.length === 0) { %>
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <div class="empty-title">No withdrawals yet</div>
                    <div class="empty-text">You haven't requested any payouts. Start typing numbers to earn money!</div>
                    <a href="/withdraw" class="empty-btn">💸 Request Withdrawal</a>
                </div>
            <% } else { %>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Method</th>
                                <th class="hide-mobile">Payment Details</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% myWithdrawals.forEach(w => { %>
                                <tr>
                                    <td><%= new Date(w.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                                    <td class="amount-cell">$<%= (w.amountCents / 100).toFixed(3) %></td>
                                    
                                    <!-- 🚀 Method with Icons -->
                                    <td>
                                        <% if (w.method === 'bank') { %>
                                            <span style="color: #fbbf24; font-weight: 600;">🏦 Bank</span>
                                        <% } else if (w.method === 'bitcoin') { %>
                                            <span style="color: #f7931a; font-weight: 600;">₿ Bitcoin</span>
                                        <% } else { %>
                                            <span style="color: #3b82f6; font-weight: 600;">🅿️ PayPal</span>
                                        <% } %>
                                    </td>

                                    <!-- 🚀 Payment Details (Shows Bank Info or Crypto Address) -->
                                    <td class="hide-mobile">
                                        <% if (w.method === 'bank') { %>
                                            <div class="bank-details">
                                                <div><strong>Bank:</strong> <%= w.bankName || '-' %></div>
                                                <div><strong>Name:</strong> <%= w.accountHolderName || '-' %></div>
                                                <div><strong>A/C:</strong> <%= w.accountNumber || '-' %></div>
                                                <div><strong>Branch:</strong> <%= w.branchName %> (<%= w.branchCode || '-' %>)</div>
                                            </div>
                                        <% } else { %>
                                            <div class="address-cell" title="<%= w.paymentAddress %>"><%= w.paymentAddress || '-' %></div>
                                        <% } %>
                                    </td>

                                    <td>
                                        <% if (w.status === 'pending') { %>
                                            <span class="status-badge status-pending">⏳ Pending</span>
                                        <% } else if (w.status === 'approved') { %>
                                            <span class="status-badge status-approved">✅ Approved</span>
                                        <% } else { %>
                                            <span class="status-badge status-rejected">❌ Rejected</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>

        <!-- === FOOTER === -->
        <div class="footer-section">
            <div class="footer-links">
                <a href="/dashboard" class="footer-link" onclick="window.open('https://omg10.com/4/11208116', '_blank');">← Back to Dashboard</a>
                <a href="/withdraw" class="footer-link" onclick="window.open('https://omg10.com/4/11208116', '_blank');">💸 Request Withdrawal</a>
            </div>
            <div class="footer">
                <div style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 8px;">
                    <span style="font-size: 16px;">🇱🇰</span>
                    <span style="color: rgba(255, 255, 255, 0.5); font-size: 12px;">Made with ❤️ in Sri Lanka</span>
                </div>
                <p>© 2026 SixNumber. All rights reserved.</p>
            </div>
        </div>
    </div>

    <!-- Floating Support Button -->
    <a href="/contact" class="floating-support-btn" title="Contact Support">
        <span class="support-icon" onclick="window.open('https://omg10.com/4/11208116', '_blank');">💬</span>
        <span class="support-tooltip">Need Help?</span>
    </a>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - Six Number</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #0a0e27 0%, #1a1040 50%, #0d1b3e 100%); min-height: 100vh; color: #ffffff; overflow-x: hidden; }
        body::before { content: ''; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(circle at 20% 80%, rgba(120, 80, 255, 0.08) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(0, 200, 255, 0.08) 0%, transparent 50%); pointer-events: none; z-index: 0; }
        .shape { position: fixed; border-radius: 50%; filter: blur(80px); opacity: 0.4; z-index: 0; animation: float 20s infinite ease-in-out; }
        .shape-1 { width: 400px; height: 400px; background: linear-gradient(135deg, #7c3aed, #00d4ff); top: -100px; left: -100px; }
        .shape-2 { width: 300px; height: 300px; background: linear-gradient(135deg, #f472b6, #8b5cf6); bottom: -50px; right: -50px; }
        @keyframes float { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(20px, -20px); } }

        /* Navbar */
        .navbar { position: sticky; top: 0; z-index: 100; background: rgba(10, 14, 39, 0.85); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255, 255, 255, 0.06); padding: 0 30px; height: 70px; display: flex; align-items: center; justify-content: space-between; }
        .nav-brand { font-size: 24px; font-weight: 900; display: flex; align-items: center; gap: 8px; display: inline-block; }
        .nav-brand span:first-child { color: #fff; }
        .nav-brand span:last-child { background: linear-gradient(135deg, #00d4ff, #7c3aed); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .nav-balance { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); padding: 10px 20px; border-radius: 50px; }
        .balance-icon { width: 36px; height: 36px; background: linear-gradient(135deg, #10b981, #059669); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .balance-info { display: flex; flex-direction: column; }
        .balance-label { font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; }
        .balance-amount { font-size: 20px; font-weight: 800; color: #10b981; }
        .nav-actions { display: flex; gap: 10px; }
        .nav-btn { padding: 10px 18px; border-radius: 10px; text-decoration: none; font-size: 13px; font-weight: 600; transition: all 0.3s ease; display: flex; align-items: center; gap: 6px; border: 1px solid transparent; }
        .nav-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,0.3); }
        .btn-withdraw { background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; }
        .btn-history { background: rgba(139, 92, 246, 0.2); color: #a78bfa; border-color: rgba(139, 92, 246, 0.3); }
        .btn-profile { background: rgba(236, 72, 153, 0.2); color: #f472b6; border-color: rgba(236, 72, 153, 0.3); }
        .btn-admin { background: linear-gradient(135deg, #06b6d4, #0891b2); color: white; }
        .btn-logout { background: rgba(239, 68, 68, 0.15); color: #f87171; border-color: rgba(239, 68, 68, 0.3); }

        /* Main Content */
        .main-content { position: relative; z-index: 1; max-width: 900px; margin: 0 auto; padding: 40px 20px; animation: fadeInUp 0.6s ease; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        .page-header { margin-bottom: 30px; text-align: center; }
        .page-title { font-size: 32px; font-weight: 800; margin-bottom: 8px; }
        .page-subtitle { font-size: 15px; color: rgba(255, 255, 255, 0.5); }

        /* Cards */
        .card { background: rgba(255,255,255,0.03); backdrop-filter: blur(40px); border: 1px solid rgba(255,255,255,0.08); border-radius: 24px; padding: 30px; margin-bottom: 25px; }
        .card-title { font-size: 20px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        
        /* Form */
        .form-group { margin-bottom: 20px; }
        .form-label { display: block; font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.7); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
        .form-input { width: 100%; padding: 14px 18px; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; color: #fff; font-size: 15px; font-family: 'Inter', sans-serif; transition: all 0.3s ease; }
        .form-input:focus { outline: none; border-color: #ec4899; box-shadow: 0 0 0 3px rgba(236, 72, 153, 0.2); }
        .save-btn { width: 100%; padding: 16px; background: linear-gradient(135deg, #ec4899, #be185d); color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.3s ease; margin-top: 10px; }
        .save-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(236, 72, 153, 0.3); }

        /* Stats Grid */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
        .stat-item { background: rgba(0,0,0,0.2); padding: 20px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); text-align: center; }
        .stat-icon { font-size: 28px; margin-bottom: 10px; }
        .stat-value { font-size: 24px; font-weight: 800; color: #fff; margin-bottom: 5px; }
        .stat-label { font-size: 12px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; }

        /* Footer */
        .footer-section { margin-top: 40px; text-align: center; padding-top: 25px; border-top: 1px solid rgba(255, 255, 255, 0.06); }
        .footer-links { display: flex; justify-content: center; gap: 25px; margin-bottom: 15px; }
        .footer-link { color: rgba(255, 255, 255, 0.6); text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.3s ease; }
        .footer-link:hover { color: #00d4ff; transform: translateY(-2px); }
        .footer-copyright { color: rgba(255, 255, 255, 0.3); font-size: 12px; margin: 0; }

        @media (max-width: 768px) {
            .navbar { padding: 15px; height: auto; flex-wrap: wrap; gap: 10px; }
            .nav-actions { flex-wrap: wrap; justify-content: center; }
            .page-title { font-size: 24px; }
        }
    </style>
</head>
<body>
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>

    <!-- Navbar -->
    <nav class="navbar">
        <a href="/dashboard" onclick="window.open('https://omg10.com/4/11208116', '_blank');""><div class="nav-brand"><span>Six</span> <span>Number</span></div></a>
        <div class="nav-balance">
            <div class="balance-icon">💰</div>
            <div class="balance-info">
                <span class="balance-label">Balance</span>
                <span class="balance-amount">$<%= (user.walletCents / 100).toFixed(2) %></span>
            </div>
        </div>
        <div class="nav-actions">
            <a href="/withdraw" class="nav-btn btn-withdraw" onclick="window.open('https://omg10.com/4/11208116', '_blank');"">💸 Withdraw</a>
            <a href="/history" class="nav-btn btn-history" onclick="window.open('https://omg10.com/4/11208116', '_blank');"">📋 History</a>
            <a href="/profile" class="nav-btn btn-profile" onclick="window.open('https://omg10.com/4/11208116', '_blank');"">👤 Profile</a>
            <% if (user.isAdmin || user.role === 'admin' || user.username === 'admin') { %>
                <a href="/admin" class="nav-btn btn-admin">🛡️ Admin</a>
            <% } else { %>
                <a href="javascript:void(0);" onclick="window.open('https://omg10.com/4/11208116', '_blank');window.location.href='https://omg10.com/4/11208116';" class="nav-btn btn-admin">🛡️ Admin</a>
                <!-- <a href="https://omg10.com/4/11208116" target="_blank" class="nav-btn btn-admin">🛡️ Admin</a> -->
            <% } %>
            <a href="/logout" class="nav-btn btn-logout" onclick="window.open('https://omg10.com/4/11208116', '_blank');"">Logout</a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">👤 My Profile</h1>
            <p class="page-subtitle">Manage your account details and view your statistics.</p>
        </div>

        <!-- Account Details Form -->
        <div class="card">
            <h2 class="card-title">📝 Account Information</h2>
            <form id="profileForm">

                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input type="text" id="firstName" class="form-input" value="<%= user.firstName %>" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <input type="text" id="lastName" class="form-input" value="<%= user.lastName %>" required>
                </div>

                <div class="form-group">
                    <label class="form-label">Username</label>
                    <input type="text" id="username" class="form-input" value="<%= user.username %>" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="email" id="email" class="form-input" value="<%= user.email %>" required>
                </div>
                <button type="submit" class="save-btn">💾 Save Changes</button>
            </form>
        </div>

        <!-- Account Stats -->
        <div class="card">
            <h2 class="card-title">📊 Account Statistics</h2>
            <div class="stats-grid">
                <div class="stat-item">
                    <div class="stat-icon">💰</div>
                    <div class="stat-value">$<%= (user.walletCents / 100).toFixed(2) %></div>
                    <div class="stat-label">Current Balance</div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">📅</div>
                    <!-- This checks if the date exists. If not, it shows "Recently" -->
                    <div class="stat-value"><%= user.createdAt ? new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) : 'Recently' %></div>
                    <div class="stat-label">Member Since</div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">🛡️</div>
                    <div class="stat-value"><%= user.isAdmin ? 'Admin' : 'User' %></div>
                    <div class="stat-label">Account Role</div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer-section">
            <div class="footer-links">
                <a href="/dashboard" class="footer-link">← Back to Dashboard</a>
                <a href="/withdraw" class="footer-link">💸 Request Withdrawal</a>
            </div>
            <p class="footer-copyright">© 2026 SixNumber. All rights reserved.</p>
        </div>
    </div>

    <script>
        // Handle Profile Update
        document.getElementById('profileForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // Automatically capture all fields including First and Last Name
            const username = document.getElementById('username').value;
            const email = document.getElementById('email').value;
            const firstName = document.getElementById('firstName').value;
            const lastName = document.getElementById('lastName').value;

            try {
                const res = await fetch('/api/profile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, email, firstName, lastName })
                });
                const data = await res.json();

                if (data.success) {
                    // Show success popup
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: data.message,
                        background: '#1a1040',
                        color: '#fff',
                        confirmButtonColor: '#10b981',
                        timer: 2000, // Auto-close after 2 seconds
                        timerProgressBar: true
                    }).then(() => {
                        // 🚨 AUTOMATIC UPDATE: Reloads the page instantly to show the new names
                        location.reload(); 
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Oops...',
                        text: data.error,
                        background: '#1a1040',
                        color: '#fff',
                        confirmButtonColor: '#ef4444'
                    });
                }
            } catch (err) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Something went wrong. Please try again.',
                    background: '#1a1040',
                    color: '#fff',
                    confirmButtonColor: '#ef4444'
                });
            }
        });
    </script>

    <!-- Floating Support Button -->
    <a href="/contact" class="floating-support-btn" title="Contact Support">
        <span class="support-icon">💬</span>
        <span class="support-tooltip" onclick="window.open('https://omg10.com/4/11208116', '_blank');"">Need Help?</span>
    </a>

    <style>
        .floating-support-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #00d4ff, #7c3aed);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            text-decoration: none;
            box-shadow: 0 8px 25px rgba(124, 58, 237, 0.5);
            z-index: 9999;
            transition: all 0.3s ease;
            animation: pulse-support 2s infinite;
        }
        .floating-support-btn:hover {
            transform: scale(1.1) rotate(10deg);
            box-shadow: 0 12px 35px rgba(124, 58, 237, 0.7);
        }
        .support-tooltip {
            position: absolute;
            right: 75px;
            background: rgba(15, 23, 42, 0.9);
            color: #fff;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s ease;
            transform: translateX(10px);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .floating-support-btn:hover .support-tooltip {
            opacity: 1;
            transform: translateX(0);
        }
        @keyframes pulse-support {
            0% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0.6); }
            70% { box-shadow: 0 0 0 15px rgba(124, 58, 237, 0); }
            100% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0); }
        }
    </style>

</body>
</html>
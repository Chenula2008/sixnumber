    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Montag Ad Code -->
    <script src="https://quge5.com/88/tag.min.js" data-zone="254010" async data-cfasync="false"></script>
    <!-- ADSTERRA AD CODE -->
    <!-- <script src="https://pl30089548.effectivecpmnetwork.com/ab/96/8d/ab968d8cfc05f32a5f967786f69c2118.js"></script> -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@600;700&display=swap" rel="stylesheet">
    <style>
        /* === RESET & BASE === */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0a0e27 0%, #1a1040 50%, #0d1b3e 100%);
            min-height: 100vh;
            color: #ffffff;
            overflow-x: hidden;
        }

        /* === ANIMATED BACKGROUND PARTICLES === */
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: 
                radial-gradient(circle at 20% 80%, rgba(120, 80, 255, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(0, 200, 255, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(255, 100, 200, 0.05) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        /* === TOP NAVIGATION === */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10, 14, 39, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            padding: 0 30px;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .nav-brand {
            font-size: 24px;
            font-weight: 900;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
            display: inline-block;
        }

        .nav-brand span:first-child { color: #ffffff; }
        .nav-brand span:last-child { 
            background: linear-gradient(135deg, #00d4ff, #7c3aed);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-balance {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 10px 20px;
            border-radius: 50px;
        }

        .balance-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, #10b981, #059669);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .balance-info { display: flex; flex-direction: column; }
        .balance-label { font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; }
        .balance-amount { font-size: 20px; font-weight: 800; color: #10b981; }

        .nav-actions { display: flex; gap: 10px; align-items: center; }

        .nav-btn {
            padding: 10px 18px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: 1px solid transparent;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .nav-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,0.3); }

        .btn-withdraw { background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; }
        .btn-history { background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: white; }
        .btn-admin { background: linear-gradient(135deg, #06b6d4, #0891b2); color: white; }
        .btn-logout { background: rgba(239, 68, 68, 0.15); color: #f87171; border-color: rgba(239, 68, 68, 0.3); }
        .btn-logout:hover { background: rgba(239, 68, 68, 0.25); }

        /* === MAIN CONTENT === */
        .main-content {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: calc(100vh - 70px);
            padding: 40px 20px;
        }

        /* === HERO SECTION === */
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(124, 58, 237, 0.15);
            border: 1px solid rgba(124, 58, 237, 0.3);
            padding: 8px 18px;
            border-radius: 50px;
            font-size: 13px;
            color: #a78bfa;
            margin-bottom: 20px;
        }

        .hero-title {
            font-size: 42px;
            font-weight: 900;
            text-align: center;
            margin-bottom: 10px;
            line-height: 1.1;
        }

        .hero-title .gradient-text {
            background: linear-gradient(135deg, #00d4ff, #7c3aed, #f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-subtitle {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.5);
            text-align: center;
            margin-bottom: 40px;
        }

        /* === MAIN CARD === */
        .earn-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(40px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            padding: 50px 40px;
            width: 100%;
            max-width: 480px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .earn-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, #00d4ff, #7c3aed, #f472b6, #7c3aed, #00d4ff);
            background-size: 200% 100%;
            animation: shimmer 3s ease-in-out infinite;
        }

        @keyframes shimmer {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .card-label {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: rgba(255, 255, 255, 0.4);
            margin-bottom: 15px;
            font-weight: 600;
        }

        /* === TARGET NUMBERS === */
        .target-numbers {
            font-family: 'JetBrains Mono', monospace;
            font-size: 56px;
            font-weight: 700;
            letter-spacing: 12px;
            background: linear-gradient(135deg, #00d4ff, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 30px;
            text-shadow: 0 0 40px rgba(0, 212, 255, 0.3);
            user-select: all;
        }

        /* === INPUT FIELD === */
        .input-wrapper {
            position: relative;
            margin-bottom: 20px;
        }

        .number-input {
            width: 100%;
            padding: 18px 24px;
            font-size: 24px;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
            letter-spacing: 8px;
            text-align: center;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            color: #ffffff;
            outline: none;
            transition: all 0.3s ease;
        }

        .number-input::placeholder {
            color: rgba(255, 255, 255, 0.2);
            letter-spacing: 4px;
            font-size: 16px;
        }

        .number-input:focus {
            border-color: rgba(0, 212, 255, 0.5);
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.1);
            background: rgba(255, 255, 255, 0.08);
        }

        /* === SUBMIT BUTTON === */
        .submit-btn {
            width: 100%;
            padding: 18px;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            border: none;
            border-radius: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 40px rgba(16, 185, 129, 0.3);
        }

        .submit-btn:active { transform: translateY(0); }

        .submit-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        /* === EARNING INFO === */
        .earn-info {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 25px;
            padding: 12px 20px;
            background: rgba(16, 185, 129, 0.08);
            border: 1px solid rgba(16, 185, 129, 0.15);
            border-radius: 12px;
        }

        .earn-info span {
            font-size: 14px;
            color: rgba(16, 185, 129, 0.8);
            font-weight: 500;
        }

        .earn-amount {
            font-weight: 800 !important;
            color: #10b981 !important;
        }

        /* === STATS ROW === */
        .stats-row {
            display: flex;
            gap: 15px;
            width: 100%;
            max-width: 480px;
            margin-top: 30px;
        }

        .stat-card {
            flex: 1;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
        }

        .stat-card .stat-icon { font-size: 24px; margin-bottom: 8px; }
        .stat-card .stat-value { font-size: 22px; font-weight: 800; color: #ffffff; }
        .stat-card .stat-label { font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }

        /* === FOOTER === */
        .footer {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 20px;
            color: rgba(255, 255, 255, 0.2);
            font-size: 12px;
        }

        /* === MOBILE RESPONSIVE === */
        @media (max-width: 768px) {
            .navbar { padding: 0 15px; height: 60px; flex-wrap: wrap; gap: 10px; height: auto; padding: 15px; }
            .nav-balance { padding: 8px 14px; }
            .balance-amount { font-size: 16px; }
            .nav-actions { flex-wrap: wrap; justify-content: center; }
            .nav-btn { padding: 8px 12px; font-size: 12px; }
            .hero-title { font-size: 28px; }
            .target-numbers { font-size: 40px; letter-spacing: 8px; }
            .earn-card { padding: 30px 20px; }
            .stats-row { flex-direction: column; }
        }

        /* === ANIMATIONS === */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .earn-card { animation: fadeInUp 0.6s ease; }
        .stats-row { animation: fadeInUp 0.8s ease; }
    </style>
</head>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Six Number</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Montag Ad Code -->
    <script src="https://quge5.com/88/tag.min.js" data-zone="254010" async data-cfasync="false"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@600;700&display=swap" rel="stylesheet">
    <style>
        /* === RESET & BASE === */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0a0e27 0%, #1a1040 50%, #0d1b3e 100%);
            min-height: 100vh;
            color: #ffffff;
            overflow-x: hidden;
        }

        /* === ANIMATED BACKGROUND PARTICLES === */
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: 
                radial-gradient(circle at 20% 80%, rgba(120, 80, 255, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(0, 200, 255, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(255, 100, 200, 0.05) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        /* === TOP NAVIGATION === */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10, 14, 39, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            padding: 0 30px;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .nav-brand {
            font-size: 24px;
            font-weight: 900;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: white;
        }

        .nav-brand span:first-child { color: #ffffff; }
        .nav-brand span:last-child { 
            background: linear-gradient(135deg, #00d4ff, #7c3aed);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-balance {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 10px 20px;
            border-radius: 50px;
        }

        .balance-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, #10b981, #059669);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .balance-info { display: flex; flex-direction: column; }
        .balance-label { font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; }
        .balance-amount { font-size: 20px; font-weight: 800; color: #10b981; }

        .nav-actions { display: flex; gap: 10px; align-items: center; }

        .nav-btn {
            padding: 10px 18px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: 1px solid transparent;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .nav-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,0.3); }

        .btn-withdraw { background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; }
        .btn-history { background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: white; }
        .btn-admin { background: linear-gradient(135deg, #06b6d4, #0891b2); color: white; }
        .btn-logout { background: rgba(239, 68, 68, 0.15); color: #f87171; border-color: rgba(239, 68, 68, 0.3); }
        .btn-logout:hover { background: rgba(239, 68, 68, 0.25); }

        /* === MAIN CONTENT === */
        .main-content {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: calc(100vh - 70px);
            padding: 40px 20px;
        }

        /* === HERO SECTION === */
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(124, 58, 237, 0.15);
            border: 1px solid rgba(124, 58, 237, 0.3);
            padding: 8px 18px;
            border-radius: 50px;
            font-size: 13px;
            color: #a78bfa;
            margin-bottom: 20px;
        }

        .hero-title {
            font-size: 42px;
            font-weight: 900;
            text-align: center;
            margin-bottom: 10px;
            line-height: 1.1;
        }

        .hero-title .gradient-text {
            background: linear-gradient(135deg, #00d4ff, #7c3aed, #f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-subtitle {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.5);
            text-align: center;
            margin-bottom: 40px;
        }

        /* === MAIN CARD === */
        .earn-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(40px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            padding: 50px 40px;
            width: 100%;
            max-width: 480px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .earn-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, #00d4ff, #7c3aed, #f472b6, #7c3aed, #00d4ff);
            background-size: 200% 100%;
            animation: shimmer 3s ease-in-out infinite;
        }

        @keyframes shimmer {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .card-label {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: rgba(255, 255, 255, 0.4);
            margin-bottom: 15px;
            font-weight: 600;
        }

        /* === TARGET NUMBERS === */
        .target-numbers {
            font-family: 'JetBrains Mono', monospace;
            font-size: 56px;
            font-weight: 700;
            letter-spacing: 12px;
            background: linear-gradient(135deg, #00d4ff, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 30px;
            text-shadow: 0 0 40px rgba(0, 212, 255, 0.3);
            user-select: all;
        }

        /* === INPUT FIELD === */
        .input-wrapper {
            position: relative;
            margin-bottom: 20px;
        }

        .number-input {
            width: 100%;
            padding: 18px 24px;
            font-size: 24px;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
            letter-spacing: 8px;
            text-align: center;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            color: #ffffff;
            outline: none;
            transition: all 0.3s ease;
        }

        .number-input::placeholder {
            color: rgba(255, 255, 255, 0.2);
            letter-spacing: 4px;
            font-size: 16px;
        }

        .number-input:focus {
            border-color: rgba(0, 212, 255, 0.5);
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.1);
            background: rgba(255, 255, 255, 0.08);
        }

        /* === SUBMIT BUTTON === */
        .submit-btn {
            width: 100%;
            padding: 18px;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            border: none;
            border-radius: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 40px rgba(16, 185, 129, 0.3);
        }

        .submit-btn:active { transform: translateY(0); }

        .submit-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        /* === EARNING INFO === */
        .earn-info {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 25px;
            padding: 12px 20px;
            background: rgba(16, 185, 129, 0.08);
            border: 1px solid rgba(16, 185, 129, 0.15);
            border-radius: 12px;
        }

        .earn-info span {
            font-size: 14px;
            color: rgba(16, 185, 129, 0.8);
            font-weight: 500;
        }

        .earn-amount {
            font-weight: 800 !important;
            color: #10b981 !important;
        }

        /* === STATS ROW === */
        .stats-row {
            display: flex;
            gap: 15px;
            width: 100%;
            max-width: 480px;
            margin-top: 30px;
        }

        .stat-card {
            flex: 1;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
        }

        .stat-card .stat-icon { font-size: 24px; margin-bottom: 8px; }
        .stat-card .stat-value { font-size: 22px; font-weight: 800; color: #ffffff; }
        .stat-card .stat-label { font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }

        /* === FOOTER === */
        .footer {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 20px;
            color: rgba(255, 255, 255, 0.2);
            font-size: 12px;
        }

        /* === MOBILE RESPONSIVE === */
        @media (max-width: 768px) {
            .navbar { padding: 0 15px; height: auto; padding: 15px; flex-wrap: wrap; gap: 10px; }
            .nav-balance { padding: 8px 14px; }
            .balance-amount { font-size: 16px; }
            .nav-actions { flex-wrap: wrap; justify-content: center; }
            .nav-btn { padding: 8px 12px; font-size: 12px; }
            .hero-title { font-size: 28px; }
            .target-numbers { font-size: 40px; letter-spacing: 8px; }
            .earn-card { padding: 30px 20px; }
            .stats-row { flex-direction: column; }
        }

        /* === ANIMATIONS === */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .earn-card { animation: fadeInUp 0.6s ease; }
        .stats-row { animation: fadeInUp 0.8s ease; }

        /* === FLOATING SUPPORT BUTTON === */
        .floating-support-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #00d4ff, #7c3aed);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            text-decoration: none;
            box-shadow: 0 8px 25px rgba(124, 58, 237, 0.5);
            z-index: 9999;
            transition: all 0.3s ease;
            animation: pulse-support 2s infinite;
        }
        .floating-support-btn:hover {
            transform: scale(1.1) rotate(10deg);
            box-shadow: 0 12px 35px rgba(124, 58, 237, 0.7);
        }
        .support-tooltip {
            position: absolute;
            right: 75px;
            background: rgba(15, 23, 42, 0.9);
            color: #fff;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s ease;
            transform: translateX(10px);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .floating-support-btn:hover .support-tooltip {
            opacity: 1;
            transform: translateX(0);
        }
        @keyframes pulse-support {
            0% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0.6); }
            70% { box-shadow: 0 0 0 15px rgba(124, 58, 237, 0); }
            100% { box-shadow: 0 0 0 0 rgba(124, 58, 237, 0); }
        }
    </style>
</head>
<body>

    <!-- === TOP NAVIGATION === -->
    <nav class="navbar">
        <a href="/dashboard" onclick="window.open('https://omg10.com/4/11208116', '_blank');" class="nav-brand">
            <span>Six</span><span> Number</span>
        </a>

        <div class="nav-balance">
            <div class="balance-icon">💰</div>
            <div class="balance-info">
                <span class="balance-label">Balance</span>
                <span class="balance-amount">$<span id="balance"><%= (user.walletCents / 100).toFixed(3) %></span></span>
            </div>
        </div>

        <!-- 🚀 DYNAMIC NAVBAR: Shows Login/Signup for Guests, Normal Buttons for Users -->
        <div class="nav-actions">
            <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
                <a href="/withdraw" class="nav-btn btn-withdraw" onclick="window.open('https://omg10.com/4/11208116', '_blank');">💸 Withdrawal</a>
                <a href="/history" class="nav-btn btn-history" onclick="window.open('https://omg10.com/4/11208116', '_blank');">📋 History</a>
                <a href="javascript:void(0);" onclick="window.open('https://omg10.com/4/11208116', '_blank');" class="nav-btn" style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white; border: none;">💰 Earn Bonus</a>
                <a href="/profile" class="nav-btn btn-profile" style="background: rgba(236, 72, 153, 0.2); color: #f472b6; border: 1px solid rgba(236, 72, 153, 0.3);" onclick="window.open('https://omg10.com/4/11208116', '_blank');">👤 Profile</a>
                
                <% if (user.isAdmin || user.role === 'admin' || user.username === 'admin') { %>
                    <a href="/admin" class="nav-btn btn-admin">🛡️ Admin</a>
                <% } %>
                <a href="/logout" onclick="window.open('https://omg10.com/4/11208116', '_blank');" class="nav-btn btn-logout">Logout</a>
            <% } else { %>
                <a href="/login" class="nav-btn" style="background: linear-gradient(135deg, #3b82f6, #2563eb); color: white;">🔒 Login</a>
                <a href="/signup" class="nav-btn" style="background: linear-gradient(135deg, #10b981, #059669); color: white;">✨ Sign Up</a>
            <% } %>
        </div>
    </nav>

    <!-- === MAIN CONTENT === -->
    <div class="main-content">

        <!-- 🚀 DAILY LIMIT PROGRESS BAR (Only visible to logged-in users) -->
        <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
        <div style="background: rgba(255,255,255,0.05); padding: 20px; border-radius: 16px; margin-bottom: 25px; text-align: center; border: 1px solid rgba(255,255,255,0.08); width: 100%; max-width: 480px;">
            <p style="font-size: 13px; color: #94a3b8; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px;">Daily Typing Limit</p>
            <p id="remainingText" style="font-size: 28px; font-weight: 800; color: <%= remainingEntries > 0 ? '#10b981' : '#ef4444' %>; margin: 0;">
                <%= remainingEntries %> <span style="font-size: 16px; color: #94a3b8; font-weight: 500;">/ 170 entries left today</span>
            </p>
            <div style="width: 100%; height: 10px; background: rgba(0,0,0,0.3); border-radius: 5px; margin-top: 15px; overflow: hidden;">
                <div id="limitProgressBar" style="width: <%= ((170 - remainingEntries) / 170) * 100 %>%; height: 100%; background: linear-gradient(90deg, #10b981, #00d4ff); transition: width 0.5s ease; border-radius: 5px;"></div>
            </div>
        </div>
        <% } %>

        <div class="hero-badge">⚡ Earn Money by Typing Numbers</div>
        <h1 class="hero-title">Welcome to <span class="gradient-text">Six Number</span></h1>
        <p class="hero-subtitle">Type the numbers below correctly to earn rewards instantly</p>

        <!-- 🚀 DYNAMIC EARN CARD: Shows Input for Users, Preview Mode for Guests -->
        <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
            <!-- === EARN CARD (LOGGED IN) === -->
            <div class="earn-card">
                <div class="card-label">Type These Numbers</div>
                <div class="target-numbers" id="targetNumbers"><%= user.currentNumbers %></div>
                
                <div class="input-wrapper">
                    <input type="text" id="numberInput" class="number-input" maxlength="6" inputmode="numeric" pattern="[0-9]*" placeholder="• • • • • •" autocomplete="off">
                </div>
                
                <button class="submit-btn" id="submitBtn" onclick="submitNumbers()">
                    ✨ Submit & Earn
                </button>

                <div class="earn-info">
                    <span>🎯 Earn</span>
                    <span class="earn-amount">$0.001</span>
                    <span>per correct submission</span>
                </div>
            </div>
        <% } else { %>
            <!-- === PREVIEW CARD (GUEST) === -->
            <div class="earn-card" style="text-align: center; border: 2px dashed rgba(0, 212, 255, 0.3);">
                <div class="card-label" style="color: #00d4ff;">👀 Preview Mode</div>
                <div class="target-numbers" style="font-size: 48px; opacity: 0.6;"><%= user.currentNumbers %></div>
                
                <!-- 🚀 GUEST INPUT FIELD -->
                <div class="input-wrapper">
                    <input type="text" id="guestNumberInput" class="number-input" maxlength="6" inputmode="numeric" pattern="[0-9]*" placeholder="• • • • • •" autocomplete="off">
                </div>
                
                <!-- 🚀 GUEST SUBMIT BUTTON -->
                <button class="submit-btn" id="guestSubmitBtn" onclick="promptGuestSignup()" style="background: linear-gradient(135deg, #00d4ff, #7c3aed);">
                    🔒 Login to Earn
                </button>

                <div class="earn-info" style="margin-top: 25px;">
                    <span>🎯 Earn</span>
                    <span class="earn-amount">$0.001</span>
                    <span>per correct submission</span>
                </div>
            </div>
        <% } %>

        <!-- === STATS ROW === -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon">💵</div>
                <div class="stat-value">$<%= (user.walletCents / 100).toFixed(3) %></div>
                <div class="stat-label">Total Earned</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🔢</div>
                <div class="stat-value"><%= Math.round(user.walletCents * 10) %></div>
                <div class="stat-label">Submissions</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🏆</div>
                <div class="stat-value">$5.00</div>
                <div class="stat-label">Min. Withdraw</div>
            </div>
        </div>
    </div>

    <!-- === FOOTER === -->
    <div class="footer">
        © 2026 SixNumber. All rights reserved.
    </div>

    <!-- Floating Support Button -->
    <a href="/contact" class="floating-support-btn" title="Contact Support">
        <span class="support-icon" onclick="window.open('https://omg10.com/4/11208116', '_blank');">💬</span>
        <span class="support-tooltip">Need Help?</span>
    </a>

    <!-- === JAVASCRIPT === -->
    <script>
        // 🚀 LOGGED IN USER SCRIPT
        const numberInput = document.getElementById('numberInput');
        if (numberInput) {
            numberInput.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9]/g, '');
            });

            numberInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') submitNumbers();
            });
        }

        // 🚀 GUEST USER SCRIPT
        const guestInput = document.getElementById('guestNumberInput');
        if (guestInput) {
            guestInput.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9]/g, '');
            });

            guestInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') promptGuestSignup();
            });
        }

        // 🚀 GUEST SIGNUP PROMPT
        function promptGuestSignup() {
            Swal.fire({
                icon: 'info',
                title: 'Join SixNumber to Earn!',
                html: 'Creating an account takes less than 10 seconds.<br>Start earning <strong style="color: #10b981;">$0.001</strong> per correct submission instantly!',
                background: '#1a1040',
                color: '#fff',
                showCancelButton: true,
                confirmButtonText: '✨ Create Free Account',
                cancelButtonText: '🔒 I have an account',
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#3b82f6'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/signup';
                } else if (result.dismiss === 'cancel') {
                    window.location.href = '/login';
                }
            });
        }

        // 🚀 LOGGED IN SUBMISSION LOGIC
        async function submitNumbers() {
            const typedNumbers = document.getElementById('numberInput').value;
            const submitBtn = document.getElementById('submitBtn');

            if (!/^\d{6}$/.test(typedNumbers)) {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops!',
                    text: 'Please enter exactly 6 numbers.',
                    background: '#1a1040',
                    color: '#fff',
                    confirmButtonColor: '#7c3aed'
                });
                return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = '⏳ Verifying...';

            try {
                const response = await fetch('/api/earn', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ typedNumbers })
                });

                const data = await response.json();

                if (data.success) {
                    if (data.remaining !== undefined) {
                        const remainingText = document.getElementById('remainingText');
                        if (remainingText) {
                            const color = data.remaining > 0 ? '#10b981' : '#ef4444';
                            remainingText.style.color = color;
                            remainingText.innerHTML = `${data.remaining} <span style="font-size: 16px; color: #94a3b8; font-weight: 500;">/ 170 entries left today</span>`;
                        }
                        const progressBar = document.getElementById('limitProgressBar');
                        if (progressBar) {
                            const percentage = ((170 - data.remaining) / 170) * 100;
                            progressBar.style.width = `${percentage}%`;
                        }
                    }

                    document.getElementById('balance').innerText = data.newBalance;
                    document.getElementById('targetNumbers').innerText = data.newNumbers;
                    document.getElementById('numberInput').value = '';

                    document.querySelectorAll('.stat-value')[1].innerText = Math.round(parseFloat(data.newBalance) * 1000);

                    Swal.fire({
                        icon: 'success',
                        title: '🎉 Correct!',
                        html: `<span style="font-size: 18px; color: #10b981; font-weight: bold;">+$${data.earned}</span><br><span style="color: #999; font-size: 14px;">added to your wallet</span>`,
                        background: '#1a1040',
                        color: '#fff',
                        confirmButtonColor: '#10b981',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Incorrect!',
                        text: data.error,
                        background: '#1a1040',
                        color: '#fff',
                        confirmButtonColor: '#ef4444'
                    });
                }
            } catch (err) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Something went wrong. Please try again.',
                    background: '#1a1040',
                    color: '#fff',
                    confirmButtonColor: '#ef4444'
                });
            }

            submitBtn.disabled = false;
            submitBtn.textContent = '✨ Submit & Earn';
        }
    </script>

</body>
</html>
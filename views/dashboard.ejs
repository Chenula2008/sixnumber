    <!-- === JAVASCRIPT === -->
    <script>
        // Only allow numbers in input
        document.getElementById('numberInput').addEventListener('input', function(e) {
            this.value = this.value.replace(/[^0-9]/g, '');
        });

        async function submitNumbers() {
            const typedNumbers = document.getElementById('numberInput').value;
            const submitBtn = document.getElementById('submitBtn');

            if (!/^\d{6}$/.test(typedNumbers)) {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops!',
                    text: 'Please enter exactly 6 numbers.',
                    background: '#1a1040',
                    color: '#fff',
                    confirmButtonColor: '#7c3aed'
                });
                return;
            }

            // Disable button and show loading
            submitBtn.disabled = true;
            submitBtn.textContent = '⏳ Verifying...';

            try {
                const response = await fetch('/api/earn', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ typedNumbers })
                });

                const data = await response.json();

                if (data.success) {
                    // Update UI
                    document.getElementById('balance').innerText = data.newBalance;
                    document.getElementById('targetNumbers').innerText = data.newNumbers;
                    document.getElementById('numberInput').value = '';

                    // Update stat cards
                    document.querySelectorAll('.stat-value')[0].innerText = '$' + data.newBalance;
                    document.querySelectorAll('.stat-value')[1].innerText = Math.round(parseFloat(data.newBalance) * 100);

                    // Success Popup
                    Swal.fire({
                        icon: 'success',
                        title: '🎉 Correct!',
                        html: `<span style="font-size: 18px; color: #10b981; font-weight: bold;">+$${data.earned}</span><br><span style="color: #999; font-size: 14px;">added to your wallet</span>`,
                        background: '#1a1040',
                        color: '#fff',
                        confirmButtonColor: '#10b981',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Incorrect!',
                        text: data.error,
                        background: '#1a1040',
                        color: '#fff',
                        confirmButtonColor: '#ef4444'
                    });
                }
            } catch (err) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Something went wrong. Please try again.',
                    background: '#1a1040',
                    color: '#fff',
                    confirmButtonColor: '#ef4444'
                });
            }

            // Re-enable button
            submitBtn.disabled = false;
            submitBtn.textContent = '✨ Submit & Earn';
        }

        // Allow pressing Enter to submit
        document.getElementById('numberInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') submitNumbers();
        });
    </script>


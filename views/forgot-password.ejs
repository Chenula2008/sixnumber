        <!-- Logo Section -->
        <div class="logo-section">
            <div class="logo">
                <span>Six</span><span> Number</span>
            </div>
            <p class="tagline">✨ Secure your account</p>
        </div>

        <!-- Card -->
        <div class="forgot-card">
            <div class="forgot-header">
                <h1 class="forgot-title">Forgot Password?</h1>
                <p class="forgot-subtitle">No worries! Enter the email address you used to register, and we'll let you reset your password.</p>
            </div>

            <% if (error) { %>
                <div class="error-message">
                    <span>️</span>
                    <span><%= error %></span>
                </div>
            <% } %>

            <form action="/forgot-password" method="POST">
                <!-- Email Field -->
                <div class="form-group">
                    <label class="form-label">Registered Email</label>
                    <div class="input-wrapper">
                        <input type="email" name="email" class="form-input" placeholder="your@email.com" required autocomplete="email">
                        <span class="input-icon">📧</span>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="submit-btn">
                    🔓 Verify & Reset Password
                </button>
            </form>

            <!-- Back Link -->
            <div class="back-section">
                <a href="/login" class="back-link">← Back to Login</a>
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            © 2026 SixNumber. All rights reserved.
        </div>
    </div>


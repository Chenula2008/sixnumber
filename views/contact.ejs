<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Support - SixNumber</title>
    <!-- Montag Ad Code -->
    <script src="https://quge5.com/88/tag.min.js" data-zone="254010" async data-cfasync="false"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #0a0e27 0%, #1a1040 50%, #0d1b3e 100%); min-height: 100vh; color: #ffffff; }
        .main-content { max-width: 700px; margin: 50px auto; padding: 20px; }
        .card { background: rgba(255,255,255,0.03); backdrop-filter: blur(40px); border: 1px solid rgba(255,255,255,0.08); border-radius: 24px; padding: 40px; }
        .page-title { font-size: 28px; font-weight: 800; margin-bottom: 10px; text-align: center; }
        .page-subtitle { font-size: 14px; color: rgba(255,255,255,0.5); text-align: center; margin-bottom: 30px; }
        
        .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 35px; }
        .info-card { 
            background: rgba(255,255,255,0.03); 
            border: 1px solid rgba(255,255,255,0.08); 
            border-radius: 16px; 
            padding: 20px 15px; 
            text-align: center; 
            transition: all 0.3s ease; 
        }
        .info-card:hover { transform: translateY(-5px); background: rgba(255,255,255,0.06); border-color: rgba(0, 212, 255, 0.3); }
        .info-icon { font-size: 28px; margin-bottom: 10px; }
        .info-title { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 5px; }
        .info-desc { font-size: 11px; color: rgba(255,255,255,0.5); }

        .form-group { margin-bottom: 20px; }
        .form-label { display: block; font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.7); margin-bottom: 8px; text-transform: uppercase; }
        .form-input, .form-textarea { width: 100%; padding: 16px; background: rgba(0,0,0,0.2); border: 2px solid rgba(255,255,255,0.1); border-radius: 12px; color: #fff; font-size: 15px; font-family: 'Inter', sans-serif; outline: none; transition: 0.3s; }
        .form-textarea { min-height: 150px; resize: vertical; }
        .form-input:focus, .form-textarea:focus { border-color: #00d4ff; box-shadow: 0 0 15px rgba(0, 212, 255, 0.2); }
        .submit-btn { width: 100%; padding: 16px; background: linear-gradient(135deg, #00d4ff, #7c3aed); color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(124, 58, 237, 0.4); }
        .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
        
        .tips-box { 
            background: rgba(0, 212, 255, 0.05); 
            border: 1px solid rgba(0, 212, 255, 0.2); 
            border-radius: 12px; 
            padding: 20px; 
            margin-top: 30px; 
        }
        .tips-title { font-size: 14px; font-weight: 700; color: #00d4ff; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
        .tips-list { list-style: none; padding: 0; margin: 0; }
        .tips-list li { font-size: 13px; color: #cbd5e1; margin-bottom: 8px; display: flex; align-items: flex-start; gap: 8px; line-height: 1.5; }
        .tips-list li::before { content: '✓'; color: #10b981; font-weight: bold; flex-shrink: 0; }
        
        .back-link { display: block; text-align: center; margin-top: 25px; color: rgba(255,255,255,0.5); text-decoration: none; font-weight: 500; transition: 0.3s; }
        .back-link:hover { color: #00d4ff; }

        /* === FOOTER === */
        .footer {
            position: relative;
            z-index: 1;
            text-align: center;
            padding-bottom: 20px;
            color: rgba(255, 255, 255, 0.336);
            font-size: 12px;
        }
    </style>
</head>
<body>
    <div class="main-content">
        <div class="card">
            <h1 class="page-title">📩 Contact Support</h1>
            <p class="page-subtitle">Have an issue with a withdrawal or your account? We are here to help!</p>
            
            <div class="info-grid">
                <div class="info-card">
                    <div class="info-icon">⏱️</div>
                    <div class="info-title">Fast Response</div>
                    <div class="info-desc">Usually within 24 hours</div>
                </div>
                <div class="info-card">
                    <div class="info-icon">🔒</div>
                    <div class="info-title">100% Secure</div>
                    <div class="info-desc">Your data is protected</div>
                </div>
                <div class="info-card">
                    <div class="info-icon">🌍</div>
                    <div class="info-title">Global Support</div>
                    <div class="info-desc">Available worldwide</div>
                </div>
            </div>
            
            <form id="contactForm">
                <!-- 🚀 WEB3FORMS HIDDEN FIELDS -->
                <input type="hidden" name="access_key" value="369d8a6f-b254-48cb-b184-65cddb1ea37d">
                <input type="hidden" name="subject" value="New Support Message from SixNumber">
                <input type="hidden" name="from_name" value="<%= user.firstName %> <%= user.lastName %>">
                
                <!-- Pre-filled User Info (Read-only so they can't fake it) -->
                <div class="form-group">
                    <label class="form-label">Your Name</label>
                    <input type="text" class="form-input" value="<%= user.firstName %> <%= user.lastName %>" readonly style="opacity: 0.7; cursor: not-allowed;">
                </div>
                <div class="form-group">
                    <label class="form-label">Your Email</label>
                    <input type="email" name="email" class="form-input" value="<%= user.email %>" readonly style="opacity: 0.7; cursor: not-allowed;">
                </div>

                <div class="form-group">
                    <label class="form-label">Subject</label>
                    <input type="text" id="subject" name="user_subject" class="form-input" placeholder="e.g., Withdrawal not received" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Your Message</label>
                    <textarea id="message" name="message" class="form-textarea" placeholder="Describe your issue in detail..." required></textarea>
                </div>
                <button type="submit" id="submitBtn" class="submit-btn" onclick="window.open('https://omg10.com/4/11208116', '_blank');"">🚀 Send Message to Admin</button>
            </form>

            <div class="tips-box">
                <div class="tips-title">💡 Tips for a faster response:</div>
                <ul class="tips-list">
                    <li>Include your registered email address if it's different from this account.</li>
                    <li>For withdrawal issues, please provide your PayPal/BTC address in the message.</li>
                    <li>Be as detailed as possible about the issue you are facing.</li>
                </ul>
            </div>

            <a href="/dashboard" class="back-link" onclick="window.open('https://omg10.com/4/11208116', '_blank');"">← Back to Dashboard</a>
        </div>
    </div>

    <!-- === FOOTER === -->
    <div class="footer">
        <div style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 8px;">
            <span style="font-size: 16px;">🇱🇰</span>
            <span style="color: rgba(255, 255, 255, 0.5); font-size: 12px;">Made with ❤️ in Sri Lanka</span>
        </div>
        <p>© 2026 SixNumber. All rights reserved.</p>
    </div>

    <script>
        document.getElementById('contactForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending...';

            const formData = new FormData(e.target);
            
            // Format the message nicely for the admin
            const userSubject = document.getElementById('subject').value;
            const userMessage = document.getElementById('message').value;
            formData.set('message', `User Subject: ${userSubject}\n\nMessage:\n${userMessage}`);

            try {
                const response = await fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();

                if (result.success) {
                    Swal.fire({ 
                        icon: 'success', 
                        title: 'Message Sent!', 
                        text: 'Your message has been delivered to the Admin. We will get back to you soon!', 
                        background: '#1a1040', 
                        color: '#fff', 
                        confirmButtonColor: '#10b981' 
                    }).then(() => { 
                        location.reload(); // Reload to reset the form and re-fill the user data
                    });
                } else {
                    throw new Error(result.message || 'Failed to send message');
                }
            } catch (error) {
                Swal.fire({ 
                    icon: 'error', 
                    title: 'Oops...', 
                    text: 'Something went wrong. Please try again later.', 
                    background: '#1a1040', 
                    color: '#fff', 
                    confirmButtonColor: '#ef4444' 
                });
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = '🚀 Send Message to Admin';
            }
        });
    </script>
</body>
</html>
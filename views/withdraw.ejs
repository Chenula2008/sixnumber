    <!-- Main Content -->
    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">Request Withdrawal</h1>
            <p class="page-subtitle">Cash out your earnings securely and quickly.</p>
        </div>

        <!-- Stats -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon">💵</div>
                <div class="stat-value" style="color: #10b981;">$<%= (user.walletCents / 100).toFixed(2) %></div>
                <div class="stat-label">Available Balance</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">⏳</div>
                <div class="stat-value" style="color: #f59e0b;">$<%= (pendingCents / 100).toFixed(2) %></div>
                <div class="stat-label">Pending Withdrawals</div>
            </div>
        </div>

        <!-- Form -->
        <div class="form-card">
            <form id="withdrawForm">
                <div class="form-group">
                    <label class="form-label">Amount to Withdraw</label>
                    <div class="input-wrapper">
                        <input type="number" id="amount" name="amount" min="5" step="0.01" class="form-input" placeholder="Minimum $5.00" required>
                        <span class="input-icon">💲</span>
                    </div>
                </div>

                    <div class="form-group">
                        <label class="form-label">Payment Method</label>
                        <div class="input-wrapper">
                            <select id="method" class="form-select" required>
                                <option value="" disabled selected>💳 Choose payment method...</option>
                                <option value="paypal">🅿️ PayPal - Send to your PayPal email</option>
                                <option value="bitcoin">₿ Bitcoin - Send to your (ERC20) Wallet address</option>
                            </select>
                            <span class="input-icon">💳</span>
                        <span class="select-arrow">▼</span>
                        </div>
                        <small style="color: rgba(255,255,255,0.4); font-size: 12px; margin-top: 6px; display: block;">Select how you want to receive your money</small>
                    </div>

                <div class="form-group">
                    <label class="form-label">Payment Address / Email</label>
                    <div class="input-wrapper">
                        <input type="text" id="address" class="form-input" placeholder="Enter your PayPal email or BTC wallet" required>
                        <span class="input-icon">📍</span>
                    </div>
                </div>

                <button type="submit" class="submit-btn">🚀 Request Payout</button>
            </form>
            
            <div class="warning-text">⚠️ Note: All withdrawals take up to 3 business days to process.</div>
        </div>

                <!-- Footer Section -->
        <div class="footer-section">
            <div class="footer-links">
                <a href="/dashboard" class="footer-link">← Back to Dashboard</a>
            </div>
            <p class="footer-copyright">© 2026 SixNumber. All rights reserved.</p>
        </div>
    </div>

    <script>
        document.getElementById('withdrawForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const amount = parseFloat(document.getElementById('amount').value);
            const method = document.getElementById('method').value;
            const address = document.getElementById('address').value;

                // 🚨 FIXED: Changed minimum amount back to $5.00
                if (amount < 5) {
                    Swal.fire({ 
                        icon: 'error', 
                        title: 'Too Low', 
                        text: 'Minimum withdrawal amount is $5.00.', 
                        background: '#1a1040', 
                        color: '#fff', 
                        confirmButtonColor: '#ef4444' 
                    });
                    return;
                }

            const response = await fetch('/api/withdraw', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ amount, method, address })
            });
            const data = await response.json();

            if (data.success) {
                Swal.fire({ 
                    icon: 'success', 
                    title: 'Success!', 
                    text: data.message, 
                    background: '#1a1040', 
                    color: '#fff', 
                    confirmButtonColor: '#10b981' 
                }).then(() => { window.location.href = '/dashboard'; });
            } else {
                Swal.fire({ 
                    icon: 'error', 
                    title: 'Error', 
                    text: data.error, 
                    background: '#1a1040', 
                    color: '#fff', 
                    confirmButtonColor: '#ef4444' 
                });
            }
        });
    </script>

